{
  "name": "infinite-canvas-x",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "pnpm --filter @infinite-canvas-x/canvas-engine build && tsc -b && vite build",
    "preview": "vite preview",
    "test": "pnpm --filter @infinite-canvas-x/canvas-engine test",
    "lint": "pnpm oxlint src",
    "lint:fix": "pnpm oxlint src --fix",
    "format": "pnpm biome format --write src",
    "check": "pnpm biome check --write src",
    "check-updates": "pnpm npm-check-updates",
    "update-packages": "pnpm npm-check-updates -u",
    "knip": "knip",
    "pre-commit": "pnpm lefthook run pre-commit",
    "pre-push": "pnpm lefthook run pre-push"
  },
  "dependencies": {
    "@infinite-canvas-x/canvas-engine": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "events": "^3.3.0",
    "lucide-react": "^0.544.0",
    "pouchdb": "^9.0.0",
    "radix-ui": "^1.4.3",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^4.1.4",
    "tiny-idb-store": "^0.1.0",
    "tw-animate-css": "^1.2.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.14.1",
    "@types/pouchdb": "^6.4.2",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "globals": "^15.15.0",
    "knip": "^5.50.5",
    "lefthook": "^1.11.10",
    "npm-check-updates": "^17.1.18",
    "oxlint": "1.57.0",
    "typescript": "~5.7.2",
    "vite": "^6.2.0"
  },
  "packageManager": "pnpm@9.15.4+sha512.b2dc20e2fc72b3e18848459b37359a32064663e5627a51e4c74b2c29dd8e8e0491483c3abb40789cfd578bf362fb6ba8261b05f0387d76792ed6e23ea3b1b6a0"
}
